        <view>
          <datasources>
            <datasource caption='HRDataset_v14' name='federated.14npfuz1iv4i3o14y9vnm0zjdcod' />
          </datasources>
          <datasource-dependencies datasource='federated.14npfuz1iv4i3o14y9vnm0zjdcod'>
            <column caption='Employee Name' datatype='string' name='[Employee_Name]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Salary]' role='measure' type='quantitative' />
            <column-instance column='[Employee_Name]' derivation='None' name='[none:Employee_Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Salary]' derivation='Sum' name='[sum:Salary:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.14npfuz1iv4i3o14y9vnm0zjdcod].[none:Employee_Name:nk]'>
            <groupfilter count='5' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='SUM([Salary])' function='order' user:ui-marker='order'>
                <groupfilter function='level-members' level='[none:Employee_Name:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
              </groupfilter>
            </groupfilter>
          </filter>
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.14npfuz1iv4i3o14y9vnm0zjdcod].[none:Employee_Name:nk]' direction='DESC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.14npfuz1iv4i3o14y9vnm0zjdcod].[sum:Salary:qk]' shelf='columns' />
          </shelf-sorts>
          <slices>
            <column>[federated.14npfuz1iv4i3o14y9vnm0zjdcod].[none:Employee_Name:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <text column='[federated.14npfuz1iv4i3o14y9vnm0zjdcod].[sum:Salary:qk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
