      <column caption=' profit ratio' datatype='real' name='[Calculation_0308187783823364]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM( [Profit] )/SUM( [Sales] )' />
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1368249927221915648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column caption='Top N Filter' datatype='boolean' name='[Calculation_1687812388048896]' role='measure' type='nominal'>
